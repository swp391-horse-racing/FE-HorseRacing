# Development: FE calls /api/v1.
# auto = use http://localhost:8080 when reachable, otherwise use deploy API.
VITE_DEV_API_ORIGIN=auto

# Optional override for axios baseURL.
# Local direct API:
# VITE_API_BASE_URL=http://localhost:8080/api/v1
# Deploy API:
# VITE_API_BASE_URL=https://api.horseracing.id.vn/api/v1
